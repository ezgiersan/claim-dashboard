{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "ES2020"],
    "module": "ESNext",
    "jsx": "react-jsx",

    "resolveJsonModule": true,
    "esModuleInterop": true,
    
    "moduleResolution": "node",
    "skipLibCheck": true,
    "noEmit": true,

    "isolatedModules": true,
    "types": ["vite/client"]
  },
  "include": ["src"]
}
